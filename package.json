{
  "name": "docflow",
  "version": "1.0.0",
  "private": true,
  "description": "DocFlow collaborative document editor monorepo.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "npm run dev --workspace server",
    "client:dev": "npm run dev --workspace client",
    "prisma:migrate": "npm run prisma:migrate --workspace server",
    "prisma:seed": "npm run prisma:seed --workspace server",
    "test": "cd server && npm test"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
